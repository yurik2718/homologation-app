# ─── Space for Edu — Environment Variables ───────────────────────────────────
# Single source of truth for all env vars the app reads.
#
# SETUP (local dev):
#   cp .env.example .env     and fill in your values
#
# SETUP (production — Kamal):
#   • Non-sensitive values → config/deploy.yml under env.clear
#   • Sensitive values     → .kamal/secrets (and list the key under env.secret)
#   See docs/20_SEO_ANALYTICS.md for the per-tool setup walkthrough.
# ──────────────────────────────────────────────────────────────────────────────


# ═══ PUBLIC CONTACT INFO ═════════════════════════════════════════════════════
# Shown on the website. VITE_-prefixed vars are baked into the client bundle.

VITE_CONTACT_WHATSAPP=34600000000
VITE_CONTACT_EMAIL=your-email@example.com
VITE_SUPPORT_EMAIL=support@example.com
VITE_CONTACT_TELEGRAM=your_telegram_handle


# ═══ STRIPE ═══════════════════════════════════════════════════════════════════
# Create a Payment Link in Stripe Dashboard → Payment Links.
# Redirect after payment to: https://yourdomain.com/es/consultation-thank-you
# If empty, the consultation button falls back to WhatsApp.

VITE_STRIPE_CONSULTATION_LINK=https://buy.stripe.com/REPLACE_ME


# ═══ APP HOST ═════════════════════════════════════════════════════════════════
# Used for canonical URLs, sitemap.xml, robots.txt Sitemap directive, and
# server-side Schema.org @id fields. Must be the absolute production URL.
# Leave empty in dev — fallback is request.base_url.

APP_HOST_URL=https://spaceforedu.com


# ═══ EMAIL (SMTP) ════════════════════════════════════════════════════════════
# Outgoing mail (password resets, notifications). Leave blank to disable.
#
# Gmail setup:
#   1. Turn on 2-Step Verification → https://myaccount.google.com/security
#   2. Create an App Password     → https://myaccount.google.com/apppasswords
#   3. Paste the 16-character password into SMTP_PASSWORD (no spaces).
#
# Note: Gmail forces your Gmail address into "From:" regardless of MAIL_FROM.
# For a branded sender on your own domain, use SendGrid / Postmark / Resend —
# they give you the same 5 values, just from their dashboard.

MAIL_FROM=Space for Edu <noreply@spaceforedu.com>
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587


# ═══ SEARCH / WEBMASTER VERIFICATION ═════════════════════════════════════════
# Each value renders a <meta> tag in <head> only when its env var is set.
#
# Where to get them:
#   Google    → search.google.com/search-console → Settings → Ownership → HTML tag
#   Yandex    → webmaster.yandex.com             → Add site → Meta tag
#   Bing      → bing.com/webmasters              → Add site → Meta tag
#   Facebook  → business.facebook.com            → Business settings → Domains

GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=
BING_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=


# ═══ GOOGLE TAG MANAGER ══════════════════════════════════════════════════════
# Only ONE env var for tracking. Inside GTM you configure tags for:
#   • GA4                  — Measurement ID G-XXXXXXXXXX
#   • Yandex.Metrica       — counter ID from metrica.yandex.com
#   • Microsoft Clarity    — project ID from clarity.microsoft.com
#   • Meta Pixel           — pixel ID from business.facebook.com
#
# Consent Mode v2 signals are set to "denied" by default and updated by the
# CMP after user consent. Configure each tag with an "Additional consent check"
# in GTM to fire only after the relevant category is granted.

GTM_ID=


# ═══ SENTRY (error tracking + performance) ═══════════════════════════════════
# Get DSNs at sentry.io → Create project → Rails (backend) + React (frontend).
# The frontend DSN is public by design (rendered in HTML meta tag).
# The backend DSN is server-only — treat as a secret in production.

SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=

# Shared across both projects
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
